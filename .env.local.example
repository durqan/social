# Local Docker Compose ports exposed to the host
FRONTEND_HOST_PORT=5173
BACKEND_HOST_PORT=8080
NOTIFICATIONS_HOST_PORT=8085
POSTGRES_HOST_PORT=5433
REDIS_HOST_PORT=6379
RABBITMQ_HOST_PORT=5672
RABBITMQ_MANAGEMENT_HOST_PORT=15672
MINIO_HOST_PORT=9000
MINIO_CONSOLE_HOST_PORT=9001

# Audit log microservice
AUDIT_HOST_PORT=8086
INTERNAL_SERVICE_TOKEN=your-long-token

# PostgreSQL container config
POSTGRES_USER=social
POSTGRES_PASSWORD=social
POSTGRES_DB=social
COMPOSE_DATABASE_URL=postgres://social:social@postgres:5432/social?sslmode=disable

# Backend / auth
PORT=8080
GIN_MODE=debug
JWT_SECRET=local-development-secret-change-before-release
# Generate with: openssl rand -base64 32
MESSAGE_ENCRYPTION_KEY=MDEyMzQ1Njc4OWFiY2RlZjAxMjM0NTY3ODlhYmNkZWY=
COOKIE_SECURE=false
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
FRONTEND_URL=http://localhost:5173

# Redis container config
COMPOSE_REDIS_HOST=redis
COMPOSE_REDIS_PORT=6379
COMPOSE_REDIS_PASSWORD=
COMPOSE_REDIS_DB=0

# RabbitMQ container config
RABBITMQ_DEFAULT_USER=guest
RABBITMQ_DEFAULT_PASS=guest
COMPOSE_RABBIT_URL=amqp://guest:guest@rabbitmq:5672/

# Notifications service
NOTIFICATIONS_INTERNAL_TOKEN=local_notifications_internal_token
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=example@example.com

# Firebase Cloud Messaging for Android push notifications
# Use either FIREBASE_SERVICE_ACCOUNT_JSON_BASE64, FIREBASE_SERVICE_ACCOUNT_JSON, or GOOGLE_APPLICATION_CREDENTIALS.
FCM_PROJECT_ID=
FIREBASE_SERVICE_ACCOUNT_JSON_BASE64=
FIREBASE_SERVICE_ACCOUNT_JSON=
GOOGLE_APPLICATION_CREDENTIALS=

# Backend storage. local uses the uploads_data Docker volume.
STORAGE_DRIVER=local
STORAGE_LOCAL_ROOT=uploads
STORAGE_PUBLIC_BASE_URL=

# Optional local MinIO/S3 settings. Keep STORAGE_DRIVER=local unless you specifically test S3 mode.
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin
S3_ENDPOINT=http://minio:9000
S3_REGION=us-east-1
S3_BUCKET=social-local
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_PUBLIC_BASE_URL=
S3_FORCE_PATH_STYLE=true

# Frontend runtime and Vite dev proxy.
# Browser calls /api and /notifications-api on localhost:5173; Vite proxies those to compose service names.
COMPOSE_VITE_API_BASE_URL=/api
COMPOSE_VITE_NOTIFICATIONS_URL=/notifications-api
COMPOSE_VITE_API_PROXY_TARGET=http://backend:8080
COMPOSE_VITE_WS_PROXY_TARGET=ws://backend:8080
COMPOSE_VITE_NOTIFICATIONS_PROXY_TARGET=http://notifications:8085
COMPOSE_CHOKIDAR_USEPOLLING=true
COMPOSE_WATCHPACK_POLLING=true
VITE_VAPID_PUBLIC_KEY=

# TURN / WebRTC audio/video calls. Optional for local LAN testing.
TURN_REALM=localhost
TURN_EXTERNAL_IP=
TURN_USERNAME=social_turn
TURN_PASSWORD=change_me_turn_password
TURN_TLS_LISTENING_PORT=5349
TURN_TLS_CERT=/etc/letsencrypt/live/turn.example.com/fullchain.pem
TURN_TLS_PKEY=/etc/letsencrypt/live/turn.example.com/privkey.pem
VITE_TURN_URLS=turn:localhost:3478?transport=udp,turns:turn.example.com:443?transport=tcp
VITE_TURN_USERNAME=social_turn
VITE_TURN_CREDENTIAL=change_me_turn_password

# React Native Android local variables, if you run mobile against this compose stack from a device/emulator.
SOCIAL_API_BASE_URL=http://10.0.2.2:8080
SOCIAL_NOTIFICATIONS_BASE_URL=http://10.0.2.2:8085
SOCIAL_TURN_URLS=turn:10.0.2.2:3478?transport=udp,turns:turn.example.com:443?transport=tcp
SOCIAL_TURN_USERNAME=social_turn
SOCIAL_TURN_CREDENTIAL=change_me_turn_password
