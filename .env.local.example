# Local Docker Compose ports exposed to the host
BACKEND_HOST_PORT=8080
POSTGRES_HOST_PORT=5433
REDIS_HOST_PORT=6379
MINIO_HOST_PORT=9000
MINIO_CONSOLE_HOST_PORT=9001

# PostgreSQL container config
POSTGRES_USER=social
POSTGRES_PASSWORD=social
POSTGRES_DB=social
COMPOSE_DATABASE_URL=postgres://social:social@postgres:5432/social?sslmode=disable

# Backend / auth
PORT=8080
GIN_MODE=debug
JWT_SECRET=local-development-secret-change-before-release
# Generate with: openssl rand -base64 32
MESSAGE_ENCRYPTION_KEY=MDEyMzQ1Njc4OWFiY2RlZjAxMjM0NTY3ODlhYmNkZWY=
COOKIE_SECURE=false
MOBILE_DEEP_LINK_PREFIX=social://

# Redis container config
COMPOSE_REDIS_HOST=redis
COMPOSE_REDIS_PORT=6379
COMPOSE_REDIS_PASSWORD=
COMPOSE_REDIS_DB=0

# Firebase Cloud Messaging for Android push notifications
# Use either FIREBASE_SERVICE_ACCOUNT_JSON_BASE64, FIREBASE_SERVICE_ACCOUNT_JSON, or GOOGLE_APPLICATION_CREDENTIALS.
FCM_PROJECT_ID=
FIREBASE_SERVICE_ACCOUNT_JSON_BASE64=
FIREBASE_SERVICE_ACCOUNT_JSON=
GOOGLE_APPLICATION_CREDENTIALS=

# Backend storage. local uses the uploads_data Docker volume.
STORAGE_DRIVER=local
STORAGE_LOCAL_ROOT=uploads
STORAGE_PUBLIC_BASE_URL=
CHAT_VIDEO_TEMP_ROOT=/tmp/chat-video-normalization
CHAT_VIDEO_NORMALIZATION_CONCURRENCY=1
CHAT_VIDEO_NORMALIZATION_TIMEOUT=20m
VIDEO_IMPORT_WORKER_CONCURRENCY=1
VIDEO_IMPORT_QUEUE_SIZE=8
VIDEO_IMPORT_TEMP_ROOT=/tmp/video-imports

# Optional local MinIO/S3 settings. Keep STORAGE_DRIVER=local unless you specifically test S3 mode.
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin
S3_ENDPOINT=http://minio:9000
S3_REGION=us-east-1
S3_BUCKET=social-local
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_PUBLIC_BASE_URL=
S3_FORCE_PATH_STYLE=true

# TURN / WebRTC audio/video calls. Optional for local LAN testing.
TURN_REALM=localhost
TURN_EXTERNAL_IP=
TURN_USERNAME=social_turn
TURN_PASSWORD=change_me_turn_password
TURN_TLS_LISTENING_PORT=5349
TURN_TLS_CERT=/etc/letsencrypt/live/turn.example.com/fullchain.pem
TURN_TLS_PKEY=/etc/letsencrypt/live/turn.example.com/privkey.pem

# React Native Android local variables, if you run mobile against this compose stack from a device/emulator.
SOCIAL_API_BASE_URL=http://10.0.2.2:8080
SOCIAL_TURN_URLS=turn:10.0.2.2:3478?transport=udp,turn:10.0.2.2:3478?transport=tcp,turns:turn.example.com:443?transport=tcp
SOCIAL_TURN_USERNAME=social_turn
SOCIAL_TURN_CREDENTIAL=change_me_turn_password
SOCIAL_WEBRTC_FORCE_RELAY=false
