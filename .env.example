# PostgreSQL
POSTGRES_USER=social
POSTGRES_PASSWORD=social
POSTGRES_DB=social

# Backend local direct-run config
DATABASE_URL=postgres://social:social@localhost:5432/social?sslmode=disable
PORT=8080
GIN_MODE=debug
JWT_SECRET=local-development-secret-change-before-release
COOKIE_SECURE=false
CORS_ALLOWED_ORIGINS=http://localhost,http://localhost:5173,http://127.0.0.1:5173
FRONTEND_URL=http://localhost:5173

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

# RabbitMQ
RABBIT_URL=amqp://guest:guest@localhost:5672/

# Notifications internal HTTP API
NOTIFICATIONS_INTERNAL_TOKEN=change_me_notifications_internal_token

# Web Push / VAPID
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:example@example.com

# Firebase Cloud Messaging for Android push notifications
# Use either FIREBASE_SERVICE_ACCOUNT_JSON_BASE64 or GOOGLE_APPLICATION_CREDENTIALS.
FCM_PROJECT_ID=
FIREBASE_SERVICE_ACCOUNT_JSON_BASE64=
FIREBASE_SERVICE_ACCOUNT_JSON=
GOOGLE_APPLICATION_CREDENTIALS=

# Backend storage. local is the default/dev driver.
STORAGE_DRIVER=local
STORAGE_LOCAL_ROOT=uploads
STORAGE_PUBLIC_BASE_URL=

# S3-compatible storage, used when STORAGE_DRIVER=s3
S3_ENDPOINT=
S3_REGION=auto
S3_BUCKET=
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
S3_SESSION_TOKEN=
S3_PUBLIC_BASE_URL=
S3_FORCE_PATH_STYLE=true

# Gmail SMTP
GMAIL_USERNAME=your_gmail_address@gmail.com
GMAIL_PASSWORD=your_gmail_app_password

# TURN / WebRTC audio calls
TURN_REALM=localhost
TURN_EXTERNAL_IP=
TURN_USERNAME=social_turn
TURN_PASSWORD=change_me_turn_password

VITE_TURN_URLS=turn:localhost:3478?transport=udp,turn:localhost:3478?transport=tcp
VITE_TURN_USERNAME=social_turn
VITE_TURN_CREDENTIAL=change_me_turn_password
VITE_NOTIFICATIONS_URL=http://localhost:8085
VITE_VAPID_PUBLIC_KEY=

# React Native Android build variables
SOCIAL_API_BASE_URL=https://example.com/api
SOCIAL_NOTIFICATIONS_BASE_URL=https://example.com/notifications-api
SOCIAL_TURN_URLS=turn:example.com:3478?transport=udp,turn:example.com:3478?transport=tcp
SOCIAL_TURN_USERNAME=social_turn
SOCIAL_TURN_CREDENTIAL=change_me_turn_password
