# PostgreSQL
POSTGRES_USER=social
POSTGRES_PASSWORD=change_me_strong_password
POSTGRES_DB=social

# Backend
DATABASE_URL=postgres://social:change_me_strong_password@postgres:5432/social?sslmode=disable
PORT=8080
GIN_MODE=release
JWT_SECRET=change_me_to_a_long_random_secret
COOKIE_SECURE=false
CORS_ALLOWED_ORIGINS=http://localhost,http://localhost:5173
FRONTEND_URL=http://localhost

# Gmail SMTP
GMAIL_USERNAME=your_gmail_address@gmail.com
GMAIL_PASSWORD=your_gmail_app_password

# TURN / WebRTC audio calls
# TURN_EXTERNAL_IP is required on a public VPS. Use the server public IPv4 address.
TURN_REALM=localhost
TURN_EXTERNAL_IP=
TURN_USERNAME=social_turn
TURN_PASSWORD=change_me_turn_password

# These values are embedded into the frontend build.
VITE_TURN_URLS=turn:localhost:3478?transport=udp,turn:localhost:3478?transport=tcp
VITE_TURN_USERNAME=social_turn
VITE_TURN_CREDENTIAL=change_me_turn_password
