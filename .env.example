# PostgreSQL
POSTGRES_USER=social
POSTGRES_PASSWORD=social
POSTGRES_DB=social

# Backend local direct-run config
DATABASE_URL=postgres://social:social@localhost:5433/social?sslmode=disable
PORT=8080
GIN_MODE=debug
JWT_SECRET=local-development-secret-change-before-release
# Generate with: openssl rand -base64 32
MESSAGE_ENCRYPTION_KEY=replace_with_base64_encoded_32_byte_key
COOKIE_SECURE=false
MOBILE_DEEP_LINK_PREFIX=social://

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

# Firebase Cloud Messaging for Android push notifications
# Use either FIREBASE_SERVICE_ACCOUNT_JSON_BASE64 or GOOGLE_APPLICATION_CREDENTIALS.
FCM_PROJECT_ID=
FIREBASE_SERVICE_ACCOUNT_JSON_BASE64=
FIREBASE_SERVICE_ACCOUNT_JSON=
GOOGLE_APPLICATION_CREDENTIALS=

# Backend storage. local is the default/dev driver.
STORAGE_DRIVER=local
STORAGE_LOCAL_ROOT=uploads
STORAGE_PUBLIC_BASE_URL=

# Uploaded chat videos are remuxed/transcoded to MP4/H.264/AAC before storage.
CHAT_VIDEO_TEMP_ROOT=/tmp/chat-video-normalization
CHAT_VIDEO_NORMALIZATION_CONCURRENCY=1
CHAT_VIDEO_NORMALIZATION_TIMEOUT=20m
VIDEO_IMPORT_WORKER_CONCURRENCY=1
VIDEO_IMPORT_QUEUE_SIZE=8
VIDEO_IMPORT_TEMP_ROOT=/tmp/video-imports

# S3-compatible storage, used when STORAGE_DRIVER=s3.
# Local MinIO defaults from docker-compose.local.yml:
#   console: http://localhost:9001
#   endpoint for backend running on host: http://localhost:9000
S3_ENDPOINT=http://localhost:9000
S3_REGION=us-east-1
S3_BUCKET=social-local
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_PUBLIC_BASE_URL=
S3_FORCE_PATH_STYLE=true

# Gmail SMTP
GMAIL_USERNAME=your_gmail_address@gmail.com
GMAIL_PASSWORD=your_gmail_app_password

# Self-hosted LiveKit. Keep API credentials on the server only.
LIVEKIT_URL=http://livekit:7880
LIVEKIT_WS_URL=wss://livekit.example.com
LIVEKIT_API_KEY=replace_with_livekit_api_key
LIVEKIT_API_SECRET=replace_with_at_least_32_random_characters

# React Native Android build variables
SOCIAL_API_BASE_URL=https://example.com/api

# YTDL (downloader video)
YTDLP_PROXY=socks5h://yt:НОВЫЙ_ПАРОЛЬ@IP:PORT
YTDLP_IMPERSONATE=chrome
YTDLP_COOKIES_FILE=
